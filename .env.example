# ════════════════════════════════════════════
#  CREDENCIAIS WOOCOMMERCE — ODONTO SCRAPING
# ════════════════════════════════════════════
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA suba o arquivo .env para o Git!

# ── URL base da loja WooCommerce (sem barra no final)
WOO_URL=https://dentalodontocirurgicajfv2.gooresultados.com.br

# ── Credenciais da API REST do WooCommerce
# Gere em: WooCommerce > Configurações > Avançado > REST API
WOO_CONSUMER_KEY=ck_COLE_SUA_CONSUMER_KEY_AQUI
WOO_CONSUMER_SECRET=cs_COLE_SUA_CONSUMER_SECRET_AQUI

# ════════════════════════════════════════════
#  MODO DE EXECUÇÃO
# ════════════════════════════════════════════

# DRY_RUN=true  → MODO TESTE: simula o envio, não toca na API real
# DRY_RUN=false → MODO PRODUÇÃO: envia de verdade ao WooCommerce
DRY_RUN=true

# Limite de URLs processadas por execução (útil para testar)
# 0 = sem limite (processa tudo que está pendente)
LIMITE_URLS=3
  
# Quantidade de produtos processados simultaneamente (Recomendado: 3 a 5)
CONCURRENCIA=3